{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Funding Partner",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "name",
    "category",
    "products",
    "minimum_revenue",
    "minimum_time_in_business_months",
    "credit_requirements",
    "industries_supported",
    "industries_restricted",
    "cta_url",
    "source_url",
    "notes"
  ],
  "properties": {
    "slug": { "type": "string" },
    "name": { "type": "string" },
    "category": { "type": "string" },
    "products": { "type": "array", "items": { "type": "string" } },
    "minimum_revenue": { "type": "number" },
    "minimum_time_in_business_months": { "type": "number" },
    "credit_requirements": { "type": ["string", "null"] },
    "industries_supported": { "type": "array", "items": { "type": "string" } },
    "industries_restricted": { "type": "array", "items": { "type": "string" } },
    "cta_url": { "type": "string" },
    "source_url": { "type": "string" },
    "notes": { "type": "string" }
  }
}
