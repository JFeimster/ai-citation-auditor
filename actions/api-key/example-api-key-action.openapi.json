{
  "openapi": "3.1.0",
  "info": {
    "title": "Example API Key Action",
    "version": "1.0.0",
    "description": "Template API-key action for a protected status endpoint."
  },
  "servers": [
    {
      "url": "https://api-key-action.invalid"
    }
  ],
  "paths": {
    "/status": {
      "get": {
        "operationId": "getStatus",
        "summary": "Get protected status",
        "description": "Returns a protected status object when the X-API-Key header is valid.",
        "parameters": [
          {
            "name": "X-API-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key header."
          }
        ],
        "responses": {
          "200": {
            "description": "Protected status response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "checked_at",
                    "account_scope"
                  ],
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "checked_at": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "account_scope": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}
